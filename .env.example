# ============================================================
# PHOENIX V2 — Environment Variables
# Copy to .env.local for local dev, or set in Cloud Run secrets
# ============================================================

# ═══ SUPABASE (REQUIRED) ═══
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key    # CRITICAL: Required for bypass RLS

# ═══ AI / LLM PROVIDERS (At least ONE required) ═══
OPENAI_API_KEY=sk-...                               # GPT-4o (ARCHITECT in DualMaster)
DEEPSEEK_API_KEY=sk-...                             # DeepSeek Chat (ORACLE in DualMaster)
GEMINI_API_KEY=AI...                                # Gemini 2.5 Flash (fallback)

# ═══ EXCHANGE: MEXC (PRIMARY — REQUIRED) ═══
MEXC_API_KEY=mx...
MEXC_API_SECRET=...

# ═══ EXCHANGE: BINANCE (FALLBACK) ═══
BINANCE_API_KEY=...
BINANCE_API_SECRET=...
BINANCE_TESTNET=false

# ═══ EXCHANGE: OKX (PRICE FALLBACK) ═══
OKX_API_KEY=...
OKX_API_SECRET=...
OKX_PASSPHRASE=...

# ═══ ACTIVE EXCHANGE ═══
ACTIVE_EXCHANGE=mexc

# ═══ NOTIFICATIONS ═══
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ═══ SOCIAL / MOLTBOOK ═══
MOLTBOOK_API_KEY=...

# ═══ SECURITY ═══
CRON_SECRET=your_random_cron_secret_here            # Protects cron endpoints
TV_SECRET_TOKEN=your_tradingview_webhook_secret      # TradingView webhook auth

# ═══ SOLANA / DeFi (Optional) ═══
BIRDEYE_API_KEY=...
RUGCHECK_API_KEY=...
JUPITER_API_KEY=...
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ═══ APP ═══
NEXT_PUBLIC_APP_NAME=Phoenix V2 Trading Engine
NODE_ENV=production
PORT=8080

# ═══ TRADING MODE GATE (ADDITIVE SAFETY — default PAPER) ═══
# PAPER: all real exchange order calls throw. Safe by default.
# LIVE:  must ALSO set LIVE_TRADING_CONFIRM=YES_I_UNDERSTAND_RISK
# If either is missing/wrong, mode collapses to PAPER.
TRADING_MODE=PAPER
LIVE_TRADING_CONFIRM=

# ═══ DASHBOARD AUTH (production refuses weak defaults) ═══
DASHBOARD_PASSWORD=           # must be >= 12 chars, not "admin123"
AUTH_SECRET=                  # must be >= 24 chars, strong random

# ═══ POLYMARKET WS (ADDITIVE LIVE FEED — Phase 2 Batch 2) ═══
# Official market channel (CLOB WS). Override if Polymarket moves endpoint.
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# Set to "true" to auto-connect on boot. Default OFF — scanner cron keeps working.
POLYMARKET_WS_AUTOSTART=false

# ═══ INTELLIGENCE LAYER (Phase 2 Batch 3 — pluggable adapters) ═══
# Comma list of news adapters to enable. Defaults cover key-less sources.
NEWS_ADAPTERS=cointelegraph-rss,coindesk-rss,cryptopanic
# Optional — enables CryptoPanic when set:
CRYPTOPANIC_KEY=
# Sentiment scorer — defaults to heuristic (key-less, rule-based).
SENTIMENT_ADAPTER=heuristic
# Cache tuning (ms)
INTEL_NEWS_CACHE_MS=60000
INTEL_SENTIMENT_CACHE_MS=90000
INTEL_SENTIMENT_HALF_LIFE_MIN=60
INTEL_RANK_STALE_MS=300000
